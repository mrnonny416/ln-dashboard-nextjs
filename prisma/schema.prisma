generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model GameSession {
  id               Int              @id @default(autoincrement())
  player_id        Int
  is_win           Boolean          @default(false)
  total_time_ms    Int?             @db.UnsignedInt
  fruits_collected Int              @default(0) @db.UnsignedInt
  started_at       DateTime         @default(now())
  ended_at         DateTime?
  Player           Player           @relation(fields: [player_id], references: [id])
  SessionAttempt   SessionAttempt[]

  @@index([player_id])
  @@index([started_at])
}

model Invoice {
  id           Int       @id @default(autoincrement())
  UserID       String    @db.VarChar(255)
  payment_hash String    @unique @db.VarChar(255)
  bolt11       String    @db.Text
  amount_sats  Int       @db.UnsignedInt
  memo         String?   @db.VarChar(255)
  status       String    @default("pending") @db.VarChar(20)
  created_at   DateTime  @default(now())
  paid_at      DateTime?

  @@index([created_at])
  @@index([status])
}

model Player {
  id          Int           @id @default(autoincrement())
  name        String        @db.VarChar(100)
  createdAt   DateTime      @default(now())
  GameSession GameSession[]
  Score       Score[]

  @@index([name])
}

model Score {
  id        Int      @id @default(autoincrement())
  player_id Int
  time_ms   Int      @db.UnsignedInt
  createdAt DateTime @default(now())
  Player    Player   @relation(fields: [player_id], references: [id])

  @@index([player_id])
  @@index([time_ms])
}

model Score_jan_feb_2026 {
  id        Int      @id @default(autoincrement())
  player_id Int
  time_ms   Int      @db.UnsignedInt
  createdAt DateTime @default(now())

  @@index([player_id], map: "Score_player_id_idx")
  @@index([time_ms], map: "Score_time_ms_idx")
}

model SessionAttempt {
  id          Int         @id @default(autoincrement())
  session_id  Int
  round_index Int         @db.UnsignedTinyInt
  time_ms     Int         @db.UnsignedInt
  created_at  DateTime    @default(now())
  GameSession GameSession @relation(fields: [session_id], references: [id], onDelete: Cascade)

  @@unique([session_id, round_index])
  @@index([session_id])
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model Test {
  column_name Int?

  @@ignore
}

model UserPlayLog {
  id             Int      @id @default(autoincrement())
  userId         String   @db.VarChar(255)
  paymentHash    String?  @db.VarChar(255)
  playCount      Int      @default(0)
  paid           Boolean  @default(false)
  scoreSubmitted Boolean  @default(false)
  lastScore      Int?
  createdAt      DateTime @default(now()) @db.DateTime(0)
  updatedAt      DateTime @default(now()) @db.DateTime(0)

  @@index([paymentHash], map: "paymentHash_idx")
  @@index([userId], map: "userId_idx")
}
