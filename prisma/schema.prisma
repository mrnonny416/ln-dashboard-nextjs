generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?   @db.Text
  passwordHash  String?
  role          Role      @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @default(now()) @updatedAt
  accounts      Account[]
  sessions      Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Invoice {
  id           Int          @id @default(autoincrement())
  player_id    String       @db.VarChar(255)
  payment_hash String       @unique @db.VarChar(255)
  bolt11       String       @db.Text
  amount_sats  Int          @db.UnsignedInt
  memo         String?      @db.VarChar(255)
  status       String       @default("pending") @db.VarChar(20)
  created_at   DateTime     @default(now())
  paid_at      DateTime?
  CollectLog   CollectLog[]
  Score        Score[]

  @@index([created_at])
  @@index([status])
}

model Player {
  id           Int      @id @default(autoincrement())
  player_id    String   @db.VarChar(255)
  payment_hash String   @db.VarChar(255)
  name         String?  @db.VarChar(100)
  createdAt    DateTime @default(now())

  @@unique([player_id, payment_hash])
  @@index([name])
  @@index([payment_hash])
  @@index([player_id])
}

model Score {
  id           Int      @id @default(autoincrement())
  player_id    String   @db.VarChar(255)
  payment_hash String   @db.VarChar(255)
  time_ms      Int      @db.UnsignedInt
  createdAt    DateTime @default(now())
  Invoice      Invoice  @relation(fields: [payment_hash], references: [payment_hash])

  @@index([player_id])
  @@index([time_ms])
  @@index([payment_hash])
}

model MaintenanceConfig {
  id                String   @id @default("main") @db.VarChar(20)
  maintenanceMode   Boolean  @default(false) @map("maintenance_mode")
  maintenanceWindow String   @default("02:00 - 04:00 UTC") @map("maintenance_window") @db.VarChar(120)
  maintenanceStatus String   @default("UPGRADING NODES") @map("maintenance_status") @db.VarChar(120)
  maintenanceNote   String   @default("กำลังอัปเกรดระบบ Lightning และประสิทธิภาพการเล่นเกม เพื่อให้ธุรกรรมเร็วและเสถียรมากขึ้น") @map("maintenance_note") @db.Text
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@map("maintenance_config")
}

model CollectLog {
  id            Int       @id @default(autoincrement())
  player_id     String    @db.VarChar(255)
  payment_hash  String    @db.VarChar(255)
  round         Int       @db.UnsignedSmallInt
  time_ms       Int?      @db.UnsignedInt
  collect_time  String?   @db.LongText
  collect_move  String?   @db.LongText
  collect_fruit String?   @db.LongText
  start_play    DateTime  @default(now())
  end_play      DateTime?
  submitted     Boolean   @default(false)
  submitted_at  DateTime?
  Invoice       Invoice   @relation(fields: [payment_hash], references: [payment_hash])

  @@unique([player_id, payment_hash, round])
  @@index([payment_hash])
  @@index([player_id])
}

enum Role {
  USER
  ADMIN
}
